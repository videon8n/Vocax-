# Vocax — variáveis de ambiente
# Copie para .env.local (dev) ou configure no painel da Vercel.
# TODAS são opcionais — sem elas, a app continua 100% funcional, só sem
# sync, analytics ou observability.

# ─── Site (recomendado configurar) ─────────────────────────────────────────
# URL canônica usada em sitemap, OG e robots
NEXT_PUBLIC_SITE_URL=https://vocax.app

# Versão pública usada em /api/health e Sentry release
NEXT_PUBLIC_APP_VERSION=0.1.0

# ─── Supabase (opcional — habilita auth + histórico) ───────────────────────
# Sem isso, login/sync ficam invisíveis no /perfil
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Apenas server-side. NUNCA exposta ao cliente.
# Necessária para apagar conta inteira (botão "Esquecer-me" com sync ativo).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─── PostHog (opcional — analytics anônimo server-side) ────────────────────
# Sem isso, /api/analytics aceita silenciosamente sem encaminhar
POSTHOG_HOST=https://eu.i.posthog.com
POSTHOG_API_KEY=phc_...

# ─── Sentry (opcional — observability) ─────────────────────────────────────
# Sem DSN, instrumentation.ts vira no-op. Para ativar: pnpm add @sentry/nextjs
NEXT_PUBLIC_SENTRY_DSN=
